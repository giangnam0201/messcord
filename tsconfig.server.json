{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "dist",
    "noEmit": false,
    "incremental": false,
    "isolatedModules": false,
    "jsx": "preserve"
  },
  "include": [
    "server.ts",
    "src/lib/socket-server.ts",
    "src/lib/io.ts",
    "src/lib/db.ts"
  ],
  "exclude": ["node_modules", "dist", ".next"]
}
