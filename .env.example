# Database (PostgreSQL - use Neon, Supabase, or Vercel Postgres)
DATABASE_URL="postgresql://user:password@host:5432/messcord?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Pusher (for real-time messaging) - get free keys at https://pusher.com
NEXT_PUBLIC_PUSHER_APP_KEY="your-pusher-key"
PUSHER_APP_ID="your-pusher-app-id"
PUSHER_SECRET="your-pusher-secret"
NEXT_PUBLIC_PUSHER_CLUSTER="us2"

# LiveKit (for voice/video/screenshare) - get free keys at https://livekit.io
LIVEKIT_API_KEY="your-livekit-api-key"
LIVEKIT_API_SECRET="your-livekit-api-secret"
NEXT_PUBLIC_LIVEKIT_URL="wss://your-project.livekit.cloud"

# Uploadthing (for file uploads) - get free keys at https://uploadthing.com
UPLOADTHING_SECRET="your-uploadthing-secret"
UPLOADTHING_APP_ID="your-uploadthing-app-id"

# Tenor GIF API (free) - get key at https://developers.google.com/tenor
NEXT_PUBLIC_TENOR_API_KEY="your-tenor-api-key"
